# =====================================
# DATABASE (Neon or Supabase Postgres)
# =====================================
# Get from neon.tech or supabase.com
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# =====================================
# CLERK AUTHENTICATION
# =====================================
# Get from clerk.com → Create app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxx"
CLERK_SECRET_KEY="sk_test_xxx"

# Clerk webhook for user sync (set up in Clerk dashboard → Webhooks)
CLERK_WEBHOOK_SECRET="whsec_xxx"

# Clerk URLs (defaults work fine)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# =====================================
# RAZORPAY (Phase 4 — payments)
# =====================================
# Get from dashboard.razorpay.com → Settings → API Keys
# Use test mode keys (rzp_test_...) for development
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxx"
RAZORPAY_KEY_ID="rzp_test_xxx"
RAZORPAY_KEY_SECRET="xxx"

# Get from dashboard.razorpay.com → Settings → Webhooks → your webhook
# Only needed in production / when testing webhooks via ngrok
RAZORPAY_WEBHOOK_SECRET="xxx"

# =====================================
# VDOCIPHER (Phase 5b — video DRM)
# =====================================
# Get from vdocipher.com → Settings → API
# Optional: lessons gracefully degrade to placeholders if not set
VDOCIPHER_API_SECRET="xxx"

# =====================================
# CLOUDINARY (Phase 5d — image uploads)
# =====================================
# Get from cloudinary.com → Dashboard → Product Environment Credentials
# Required for: course cover images, profile pictures, custom tech-stack logos
# The NEXT_PUBLIC_ vars are exposed to the browser (safe by Cloudinary's design)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="ua_uploads"
CLOUDINARY_API_KEY="xxx"
CLOUDINARY_API_SECRET="xxx"

# =====================================
# RESEND EMAIL (added in Phase 6)
# =====================================
# RESEND_API_KEY="re_xxx"
# EMAIL_FROM="Unified Automation <noreply@yourdomain.com>"

# =====================================
# APP CONFIG
# =====================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
